@baseUrl = http://localhost:8080

### ============================================================
### A — Collectivités
### ============================================================

### A-1 : Créer une nouvelle collectivité
POST {{baseUrl}}/collectivities
Content-Type: application/json

[
  {
    "location": "Fianarantsoa",
    "federationApproval": true,
    "memberIds": ["C1-M1","C1-M2","C1-M3","C1-M4","C1-M5","C1-M6","C1-M7","C1-M8"],
    "structure": {
      "presidentId":     "C1-M1",
      "vicePresidentId": "C1-M2",
      "treasurerId":     "C1-M4",
      "secretaryId":     "C1-M3"
    }
  }
]

###

### A-2 : Créer sans approbation fédération → 400
POST {{baseUrl}}/collectivities
Content-Type: application/json

[
  {
    "location": "Toliara",
    "federationApproval": false,
    "memberIds": ["C1-M1","C1-M2"],
    "structure": {
      "presidentId":     "C1-M1",
      "vicePresidentId": "C1-M2",
      "treasurerId":     "C1-M2",
      "secretaryId":     "C1-M2"
    }
  }
]

###

### A-3 : Récupérer une collectivité par son ID
GET {{baseUrl}}/collectivities/col-1

###

### A-4 : Collectivité inexistante → 404
GET {{baseUrl}}/collectivities/col-999

###

### ============================================================
### J — Attribution numéro + nom
### PUT /collectivities/{id}/informations
### ============================================================

### J-1 : Attribuer numéro et nom (collectivité sans identification)
PUT {{baseUrl}}/collectivities/col-4/informations
Content-Type: application/json

{
  "number": "4",
  "name": "Vokatra Tsara"
}

###

### J-2 : Modifier une collectivité déjà identifiée → 409
PUT {{baseUrl}}/collectivities/col-1/informations
Content-Type: application/json

{
  "number": "99",
  "name": "Doublon"
}

###

### J-3 : Nom déjà utilisé par une autre collectivité → 400
PUT {{baseUrl}}/collectivities/col-2/informations
Content-Type: application/json

{
  "number": "5",
  "name": "Mpanorina"
}

###

### ============================================================
### B-2 — Admission d'un nouveau membre
### POST /members
### ============================================================

### B-1 : Admission valide — 2 parrains de la même collectivité
POST {{baseUrl}}/members
Content-Type: application/json

[
  {
    "firstName":              "Heritiana",
    "lastName":               "Rakoto",
    "birthDate":              "2000-06-15",
    "gender":                 "MALE",
    "address":                "Lot 40 Ambatondrazaka",
    "profession":             "Agriculteur",
    "phoneNumber":            "0341111111",
    "email":                  "heritiana.rakoto@test.mg",
    "collectivityIdentifier": "col-1",
    "referees": [
      { "memberId": "C1-M5", "relationship": "Ami" },
      { "memberId": "C1-M6", "relationship": "Collègue" }
    ],
    "registrationFeePaid":  true,
    "membershipDuesPaid":   true
  }
]

###

### B-2 : 1 parrain col-1 + 1 parrain col-2 (≥ 50 % col-1 → autorisé)
POST {{baseUrl}}/members
Content-Type: application/json

[
  {
    "firstName":              "Volana",
    "lastName":               "Rasoamahenina",
    "birthDate":              "1995-03-20",
    "gender":                 "FEMALE",
    "address":                "Lot 22 Ambatondrazaka",
    "profession":             "Riziculteur",
    "phoneNumber":            "0342222222",
    "email":                  "volana.raso@test.mg",
    "collectivityIdentifier": "col-1",
    "referees": [
      { "memberId": "C1-M5", "relationship": "Famille" },
      { "memberId": "C1-M1", "relationship": "Voisin" }
    ],
    "registrationFeePaid":  true,
    "membershipDuesPaid":   true
  }
]

###

### B-3 : 2 parrains hors col-1 → refusé → 400
POST {{baseUrl}}/members
Content-Type: application/json

[
  {
    "firstName":              "Fidy",
    "lastName":               "Andriamanantena",
    "birthDate":              "1998-11-11",
    "gender":                 "MALE",
    "address":                "Lot 5 Antsirabe",
    "profession":             "Collecteur",
    "phoneNumber":            "0343333333",
    "email":                  "fidy.andria@test.mg",
    "collectivityIdentifier": "col-1",
    "referees": [
      { "memberId": "C3-M1", "relationship": "Ami" },
      { "memberId": "C3-M2", "relationship": "Ami" }
    ],
    "registrationFeePaid":  true,
    "membershipDuesPaid":   true
  }
]

###

### B-4 : Frais non réglés → 400
POST {{baseUrl}}/members
Content-Type: application/json

[
  {
    "firstName":              "Tojo",
    "lastName":               "Raharison",
    "birthDate":              "2001-01-01",
    "gender":                 "MALE",
    "address":                "Lot 99 Ambato",
    "profession":             "Technicien",
    "phoneNumber":            "0344444444",
    "email":                  "tojo.raharison@test.mg",
    "collectivityIdentifier": "col-1",
    "referees": [
      { "memberId": "C1-M5", "relationship": "Ami" },
      { "memberId": "C1-M6", "relationship": "Ami" }
    ],
