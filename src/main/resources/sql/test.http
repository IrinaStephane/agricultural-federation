### ──────────────────────────────────────────────────────────────────────────
### POST /members/1/payments — paiement CASH (201) ✅
### Membre 1, cotisation mensuelle id=1, compte caisse id=1
### ──────────────────────────────────────────────────────────────────────────
POST http://localhost:8080/members/1/payments
Content-Type: application/json

[
  {
    "amount": 10000.00,
    "membershipFeeIdentifier": 1,
    "accountCreditedIdentifier": 1,
    "paymentMode": "CASH"
  }
]

###

### ──────────────────────────────────────────────────────────────────────────
### POST /members/2/payments — paiements multiples en une requête (201) ✅
### Mobile money + cash pour deux cotisations différentes
### ──────────────────────────────────────────────────────────────────────────
POST http://localhost:8080/members/2/payments
Content-Type: application/json

[
  {
    "amount": 10000.00,
    "membershipFeeIdentifier": 1,
    "accountCreditedIdentifier": 2,
    "paymentMode": "MOBILE_BANKING"
  },
  {
    "amount": 100000.00,
    "membershipFeeIdentifier": 2,
    "accountCreditedIdentifier": 1,
    "paymentMode": "CASH"
  }
]

###

